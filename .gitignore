# ============================================
# Terraform
# ============================================

# Terraform working directory

**/.terraform/*

# Keep provider lock file

!.terraform.lock.hcl

# Terraform state files

*.tfstate
*.tfstate.*

# Terraform plan files

*.tfplan
*.plan

# Variable files (may contain secrets)

terraform.tfvars
*.auto.tfvars

# Override files

override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration

.terraformrc
terraform.rc

# Crash logs

crash.log
crash.*.log

# ============================================
# Secrets
# ============================================

*.pem
*.key

# ============================================
# IDE
# ============================================

.vscode/
.idea/

# ============================================
# Operating System
# ============================================

.DS_Store
Thumbs.db
desktop.ini
